# Токен Telegram бота (получить у @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ID администраторов бота (список чисел)
ADMIN_IDS= [123456789,987654321]

# Количество дней активности пользователей для парсинга
ACTIVE_DAYS=30

# Минимальная задержка между отправками (секунды)
SEND_DELAY_MIN=30

# Максимальная задержка между отправками (секунды)
SEND_DELAY_MAX=90

# Максимальное количество сообщений с одного аккаунта в день
MAX_PER_ACCOUNT=40

# Максимальное количество повторных попыток при ошибке
MAX_RETRIES=3

# URL базы данных
DB_URL=sqlite+aiosqlite:///data/tg_parser.db

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
