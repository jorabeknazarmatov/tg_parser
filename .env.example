# ===== Telegram Bot =====
# Токен бота от @BotFather
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# ID администраторов через запятую (можно несколько)
ADMIN_IDS=123456789,987654321

# ===== Telegram API =====
# Получить на https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ===== Настройки парсера =====
# Активность за сколько последних дней учитывать
ACTIVE_DAYS=30

# ===== Настройки отправки =====
# Минимальная задержка между сообщениями (в секундах)
SEND_DELAY_MIN=30

# Максимальная задержка между сообщениями (в секундах)
SEND_DELAY_MAX=90

# Максимум отправок на один аккаунт в день
MAX_PER_ACCOUNT=40

# Максимальное количество попыток при ошибке
MAX_RETRIES=3

# ===== База данных =====
DB_URL=sqlite+aiosqlite:///data/tg_parser.db

# ===== Логирование =====
# Уровень логов: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
